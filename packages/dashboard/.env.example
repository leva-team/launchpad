# AWS
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=

# Cognito (Dashboard login)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_DOMAIN=launchpad.auth.ap-northeast-2.amazoncognito.com
COGNITO_USER_POOL_ARN=

# Cognito (ALB auth for sandboxes - separate client with secret)
COGNITO_ALB_CLIENT_ID=

# Route53
ROUTE53_HOSTED_ZONE_ID=

# EC2 Sandbox
LAUNCH_TEMPLATE_ID=
SANDBOX_SECURITY_GROUP_ID=
SANDBOX_SUBNET_IDS=subnet-xxx,subnet-yyy
VPC_ID=

# ALB
ALB_LISTENER_ARN=

# DynamoDB
DYNAMO_TABLE_NAME=launchpad-sandboxes

# App
NEXT_PUBLIC_BASE_URL=https://launchpad.example.com
NEXTAUTH_URL=https://launchpad.example.com
NEXTAUTH_SECRET=change-me-in-production
