# AWS
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_DOMAIN=launchpad.auth.ap-northeast-2.amazoncognito.com

# Route53
ROUTE53_HOSTED_ZONE_ID=
BASE_DOMAIN=adreamer.now

# EC2
LAUNCH_TEMPLATE_ID=
SANDBOX_SECURITY_GROUP_ID=
SANDBOX_SUBNET_IDS=subnet-xxx,subnet-yyy
SANDBOX_AMI_PARAMETER=/${PROJECT_PREFIX}/sandbox/ami-id

# DynamoDB
DYNAMO_TABLE_NAME=launchpad-sandboxes

# App
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me-in-production
